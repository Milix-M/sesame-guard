# SESAME Biz API
SESAME_API_KEY=your_api_key_here
SESAME_SECRET_KEY=your_secret_key_here  # Required for control commands (lock/unlock)
SESAME_DEVICE_ID=your_sesame_uuid_here

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_USER_ID=your_line_user_id_here

# Risk detection (defaults shown)
# RISK_NIGHT_START=2
# RISK_NIGHT_END=5
# RISK_RAPID_THRESHOLD_SEC=300
# RISK_RAPID_COUNT=3
# RISK_UNLOCK_TIMEOUT_MIN=120
# RISK_COOLDOWN_MIN=30
# RISK_ANOMALY_SIGMA=2.0

# Polling
# POLL_INTERVAL_SEC=60
# DB_PATH=sesame_guard.db
